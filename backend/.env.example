# Copy this file to .env and update values before running the backend.

PORT=3000
MONGODB_URI=mongodb://localhost:27017
JWT_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:5173
COOKIE_SECURE=false
JWT_EXPIRES_IN=1d
JWT_SLIDING_THRESHOLD=6h
ALLOW_BEARER_AUTH=false

# MONGODB_URI: local MongoDB or Atlas connection string
# JWT_SECRET: use a long random string in production
# FRONTEND_URL: origin allowed for CORS with credentials (production)
# COOKIE_SECURE: set true in production (requires HTTPS)
# JWT_EXPIRES_IN: access token lifetime (jsonwebtoken format, e.g. 1d, 12h)
# JWT_SLIDING_THRESHOLD: re-issue cookie when less than this remains (e.g. 6h)
# ALLOW_BEARER_AUTH: set true only for local API tooling; disabled in production
#
# Frontend CSP: update connect-src in frontend/index.html to include your production API origin
# Note: master password is never stored on the server.
